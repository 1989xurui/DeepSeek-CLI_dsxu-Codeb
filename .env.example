DSXU_CODE_MODE=1
DSXU_PRODUCT_NAME=DSXU Code
DSXU_MODEL_PROVIDER=deepseek
DSXU_MODEL_GATEWAY=direct
DSXU_MODEL=deepseek-v4-flash

# Choose one direct key variable. DSXU auth paths prefer DSXU_API_KEY,
# then DEEPSEEK_API_KEY, then DSXU_DEEPSEEK_API_KEY.
DSXU_API_KEY=your_key_here
# DEEPSEEK_API_KEY=your_deepseek_key_here
# DSXU_DEEPSEEK_API_KEY=your_deepseek_key_here

# Optional local gateway/proxy.
# LITELLM_BASE_URL=http://127.0.0.1:4000
# DEEPSEEK_BASE_URL=https://api.deepseek.com

API_TIMEOUT_MS=3000000
DISABLE_TELEMETRY=1
