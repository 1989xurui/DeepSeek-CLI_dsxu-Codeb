    reg.register(mutateTool)
    reg.register(failTool)

    const gen = queryLoop(
      {
        llmCall: llm,
        cwd,
        telemetry: { collector: telemetry },
        toolTransaction: { enabled: true, rollbackOnToolError: true },
        toolExecution: { mode: 'sequential' },
      },
      [{ role: 'user', content: 'transaction telemetry summary test' }],
      reg,
    )
    const { result } = await collectEvents(gen)

    expect(result.exitReason).toBe('end_turn')
    const txSummary = telemetry.getTransactionSummary()
    expect(txSummary.startedCount).toBeGreaterThanOrEqual(1)
