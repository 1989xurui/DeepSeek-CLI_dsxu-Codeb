      inputSchema: { type: 'object', properties: { file_path: { type: 'string' }, text: { type: 'string' } } },
      execute: async (input) => {
        writeFileSync(String(input.file_path), String(input.text))
        return { content: 'mutated' }
      },
    }
    const telemetry = new TelemetryCollector('tx-telemetry')

    const llm = createMockLLMCall([
      mockResponse('Mutate then fail', [
        { id: 'call-1', name: 'EditFile', arguments: { file_path: target, text: 'after\n' } },
        { id: 'call-2', name: 'fail', arguments: {} },
      ]),
